{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/jschwefel-CBB/autopilot/blob/main/schema/plan.schema.json",
  "title": "AutoPilot Test Plan",
  "description": "A declarative GUI test plan executed by AutoPilot. See docs/AUTHORING.md.",
  "type": "object",
  "required": ["schemaVersion", "name", "target", "steps"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "name": { "type": "string" },
    "include": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Sub-plan files to prepend; resolved relative to THIS plan file."
    },
    "target": { "$ref": "#/$defs/target" },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timeoutMs": { "type": "integer", "minimum": 0 },
        "retryIntervalMs": { "type": "integer", "minimum": 1 }
      }
    },
    "steps": { "type": "array", "items": { "$ref": "#/$defs/step" } }
  },
  "$defs": {
    "target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bundleId": { "type": "string" },
        "path": { "type": "string", "description": "Path to a real .app bundle." },
        "launchArgs": { "type": "array", "items": { "type": "string" } },
        "launchFiles": { "type": "array", "items": { "type": "string" } }
      },
      "anyOf": [{ "required": ["bundleId"] }, { "required": ["path"] }]
    },
    "selector": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "role": { "type": "string", "description": "AX role, e.g. AXButton, AXTextArea." },
        "identifier": { "type": "string", "description": "AXIdentifier — the preferred locator." },
        "title": { "type": "string" },
        "value": { "type": "string" },
        "label": { "type": "string", "description": "NON-FUNCTIONAL — never matches; use title/identifier." },
        "path": { "type": "array", "items": { "type": "string" }, "description": "NON-FUNCTIONAL — ignored." },
        "index": { "type": "integer", "minimum": 0, "description": "Pick the nth match when ambiguous." },
        "within": { "$ref": "#/$defs/selector", "description": "Scope to inside this parent element." },
        "vision": {
          "type": "object",
          "additionalProperties": false,
          "required": ["image", "confidence"],
          "properties": {
            "image": { "type": "string" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["property", "op"],
      "properties": {
        "property": {
          "enum": ["value", "title", "enabled", "focused", "position", "size", "exists", "marked"]
        },
        "op": {
          "enum": ["equals", "notEquals", "contains", "matches", "exists", "notExists", "greaterThan", "lessThan"]
        },
        "expected": { "type": "string" }
      }
    },
    "args": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "text": { "type": "string" },
        "clear": { "type": "boolean" },
        "commit": { "type": "boolean" },
        "focus": { "type": "boolean", "description": "false = don't focus-click (already-focused fields)." },
        "keys": { "type": "string", "description": "Chord, e.g. cmd+s, cmd+,, cmd+plus." },
        "menuPath": { "type": "array", "items": { "type": "string" } },
        "to": { "$ref": "#/$defs/selector" },
        "toFiles": { "type": "array", "items": { "type": "string" }, "description": "NOT supported via synthetic events." },
        "deltaX": { "type": "integer" },
        "deltaY": { "type": "integer" },
        "seconds": { "type": "number" },
        "path": { "type": "string" },
        "present": { "type": "boolean" },
        "color": { "type": "string", "pattern": "^#?[0-9A-Fa-f]{6}$" },
        "tolerance": { "type": "number" },
        "width": { "type": "integer" },
        "height": { "type": "integer" },
        "mode": { "enum": ["average", "dominant"] },
        "reference": { "type": "string" },
        "maxDiff": { "type": "number", "minimum": 0, "maximum": 1 },
        "offsetX": { "type": "integer" },
        "offsetY": { "type": "integer" },
        "atX": { "type": "integer" },
        "atY": { "type": "integer" }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "action"],
      "properties": {
        "id": { "type": "string" },
        "action": {
          "enum": [
            "launch", "terminate", "click", "doubleClick", "rightClick", "press",
            "menu", "type", "keyPress", "setValue", "scroll", "drag",
            "assertPixel", "assertRegion", "snapshot", "waitFor", "screenshot",
            "assert", "wait"
          ]
        },
        "target": { "$ref": "#/$defs/selector" },
        "args": { "$ref": "#/$defs/args" },
        "assert": { "$ref": "#/$defs/assertion" },
        "timeoutMs": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
