{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/jschwefel-CBB/autopilot/blob/main/schema/plan.schema.json",
  "title": "AutoPilot Test Plan",
  "description": "A declarative GUI test plan executed by AutoPilot. See docs/AUTHORING.md.",
  "type": "object",
  "required": [
    "schemaVersion",
    "name",
    "target",
    "steps"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "name": {
      "type": "string"
    },
    "include": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Sub-plan files to prepend; resolved relative to THIS plan file."
    },
    "target": {
      "$ref": "#/$defs/target"
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timeoutMs": {
          "type": "integer",
          "minimum": 0
        },
        "retryIntervalMs": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/step"
      }
    }
  },
  "$defs": {
    "target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bundleId": {
          "type": "string"
        },
        "path": {
          "type": "string",
          "description": "Path to a real .app bundle."
        },
        "launchArgs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "launchFiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "bundleId"
          ]
        },
        {
          "required": [
            "path"
          ]
        }
      ]
    },
    "selector": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "role": {
          "type": "string",
          "description": "AX role, e.g. AXButton, AXTextArea."
        },
        "identifier": {
          "type": "string",
          "description": "AXIdentifier \u2014 the preferred locator."
        },
        "title": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "index": {
          "type": "integer",
          "minimum": 0,
          "description": "Pick the nth match when ambiguous."
        },
        "within": {
          "$ref": "#/$defs/selector",
          "description": "Scope to inside this parent element."
        },
        "vision": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "image",
            "confidence"
          ],
          "properties": {
            "image": {
              "type": "string"
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        }
      }
    },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "property",
        "op"
      ],
      "properties": {
        "property": {
          "enum": [
            "value",
            "title",
            "enabled",
            "focused",
            "position",
            "size",
            "marked",
            "count"
          ]
        },
        "op": {
          "enum": [
            "equals",
            "notEquals",
            "contains",
            "matches",
            "exists",
            "notExists",
            "greaterThan",
            "lessThan"
          ]
        },
        "expected": {
          "type": "string"
        }
      }
    },
    "args": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "text": {
          "type": "string"
        },
        "clear": {
          "type": "boolean"
        },
        "commit": {
          "type": "boolean"
        },
        "focus": {
          "type": "boolean",
          "description": "false = don't focus-click (already-focused fields)."
        },
        "keys": {
          "type": "string",
          "description": "Chord, e.g. cmd+s, cmd+,, cmd+plus."
        },
        "menuPath": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "to": {
          "$ref": "#/$defs/selector"
        },
        "toFiles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "NOT supported via synthetic events."
        },
        "deltaX": {
          "type": "integer"
        },
        "deltaY": {
          "type": "integer"
        },
        "seconds": {
          "type": "number"
        },
        "path": {
          "type": "string"
        },
        "present": {
          "type": "boolean"
        },
        "color": {
          "type": "string",
          "pattern": "^#?[0-9A-Fa-f]{6}$"
        },
        "tolerance": {
          "type": "number"
        },
        "width": {
          "type": "integer"
        },
        "height": {
          "type": "integer"
        },
        "mode": {
          "enum": [
            "average",
            "dominant"
          ]
        },
        "reference": {
          "type": "string"
        },
        "maxDiff": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "offsetX": {
          "type": "integer"
        },
        "offsetY": {
          "type": "integer"
        },
        "atX": {
          "type": "integer"
        },
        "atY": {
          "type": "integer"
        },
        "padding": {
          "type": "number",
          "minimum": 0,
          "description": "Points of padding added around the element frame on all sides for screenshot / captureTarget captures."
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "action"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "action": {
          "enum": [
            "launch",
            "terminate",
            "click",
            "doubleClick",
            "rightClick",
            "press",
            "menu",
            "type",
            "keyPress",
            "setValue",
            "scroll",
            "drag",
            "assertPixel",
            "assertRegion",
            "snapshot",
            "waitFor",
            "screenshot",
            "assert",
            "wait"
          ]
        },
        "target": {
          "$ref": "#/$defs/selector"
        },
        "args": {
          "$ref": "#/$defs/args"
        },
        "assert": {
          "$ref": "#/$defs/assertion"
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 0
        },
        "captureTarget": {
          "type": "boolean",
          "description": "When true, AutoPilot saves a cropped screenshot of the step's target element (pass or fail) alongside the normal full-display failure shot. Useful for building a visual log without explicit screenshot steps."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "enum": [
                  "click",
                  "doubleClick",
                  "rightClick",
                  "press",
                  "type",
                  "keyPress",
                  "setValue",
                  "scroll",
                  "drag",
                  "waitFor",
                  "assert"
                ]
              }
            }
          },
          "then": {
            "required": [
              "target"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "type"
              }
            }
          },
          "then": {
            "properties": {
              "args": {
                "required": [
                  "text"
                ]
              }
            },
            "required": [
              "args"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "setValue"
              }
            }
          },
          "then": {
            "properties": {
              "args": {
                "required": [
                  "text"
                ]
              }
            },
            "required": [
              "args"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "keyPress"
              }
            }
          },
          "then": {
            "properties": {
              "args": {
                "required": [
                  "keys"
                ]
              }
            },
            "required": [
              "args"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "menu"
              }
            }
          },
          "then": {
            "properties": {
              "args": {
                "required": [
                  "menuPath"
                ]
              }
            },
            "required": [
              "args"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "assert"
              }
            }
          },
          "then": {
            "required": [
              "assert"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "snapshot"
              }
            }
          },
          "then": {
            "properties": {
              "args": {
                "required": [
                  "reference"
                ]
              }
            },
            "required": [
              "args"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "enum": [
                  "assertPixel",
                  "assertRegion"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "args": {
                "required": [
                  "color"
                ]
              }
            },
            "required": [
              "args"
            ]
          }
        }
      ]
    }
  }
}